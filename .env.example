# ===================================
# PARAVIBE BACKEND - ENVIRONMENT VARIABLES
# ===================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control!

# -----------------------------------
# Server Configuration
# -----------------------------------
PORT=8080
CORS_ORIGIN=3000

# -----------------------------------
# Database Configuration (MySQL)
# -----------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=paravibe
DB_PASS=your_database_password_here
DB_NAME=paravibe_db

# -----------------------------------
# JWT Authentication
# -----------------------------------
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# -----------------------------------
# AI Service URL
# -----------------------------------
# Python FastAPI service for embeddings and recommendations
AI_SERVICE_URL=http://localhost:8000

# -----------------------------------
# Genius API Configuration (Required)
# -----------------------------------
# Required for lyrics fetching and lyric embeddings
# Get your token at: https://genius.com/api-clients
GENIUS_CLIENT_ID=your_genius_client_id_here
GENIUS_CLIENT_SECRET=your_genius_client_secret_here
GENIUS_ACCESS_TOKEN=your_genius_access_token_here

# -----------------------------------
# Notes:
# -----------------------------------
# 1. Apple Music (iTunes Search API): NO authentication required!
#    - Completely free, no API key needed
#    - Provides 30s audio previews for all tracks
#    - Perfect for audio embeddings and music player
#
# 2. Genius API: Required for fetching lyrics
#    - Free tier available
#    - Used for lyric embeddings
#
# 3. AI Service: Must be running on port 8000
#    - Handles MERT (audio) and SBERT (lyrics) embeddings
#    - Python FastAPI service
#
# 4. Database: MySQL must be running
#    - Create database before running migrations
#    - Run: CREATE DATABASE paravibe_db;
