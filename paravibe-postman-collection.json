    {
      "name": "Recommendations",
      "description": "Song and user-based recommendations using embeddings",
      "item": [
        {
          "name": "Get Song-Based Recommendations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/recommendations/song/1?topK=5",
              "host": ["{{base_url}}"],
              "path": ["recommendations", "song", "1"],
              "query": [
                {
                  "key": "topK",
                  "value": "5",
                  "description": "Number of recommendations to return"
                }
              ]
            },
            "description": "Get recommendations based on a specific song using audio and metadata embeddings (60% audio similarity + 40% metadata similarity)"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is array of recommendations', function() {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Recommendations have required fields', function() {",
                  "    const recommendations = pm.response.json();",
                  "    if (recommendations.length > 0) {",
                  "        pm.expect(recommendations[0]).to.have.property('songId');",
                  "        pm.expect(recommendations[0]).to.have.property('title');",
                  "        pm.expect(recommendations[0]).to.have.property('artistName');",
                  "        pm.expect(recommendations[0]).to.have.property('genre');",
                  "        pm.expect(recommendations[0]).to.have.property('score');",
                  "    }",
                  "});",
                  "",
                  "pm.test('Similarity scores are between 0 and 1', function() {",
                  "    const recommendations = pm.response.json();",
                  "    recommendations.forEach(function(rec) {",
                  "        pm.expect(rec.score).to.be.above(0);",
                  "        pm.expect(rec.score).to.be.below(1);",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User-Based Recommendations",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/recommendations/user/10?topK=10",
              "host": ["{{base_url}}"],
              "path": ["recommendations", "user", "10"],
              "query": [
                {
                  "key": "topK",
                  "value": "10",
                  "description": "Number of recommendations to return"
                }
              ]
            },
            "description": "Get personalized recommendations based on user listening history. Creates average embedding vector from top 20 listened songs and compares against entire database (60% audio similarity + 40% metadata similarity)"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is array of recommendations', function() {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('All recommendations have required fields', function() {",
                  "    const recommendations = pm.response.json();",
                  "    recommendations.forEach(function(rec) {",
                  "        pm.expect(rec).to.have.property('songId');",
                  "        pm.expect(rec).to.have.property('title');",
                  "        pm.expect(rec).to.have.property('artistName');",
                  "        pm.expect(rec).to.have.property('genre');",
                  "        pm.expect(rec).to.have.property('score');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Recommendations sorted by score descending', function() {",
                  "    const recommendations = pm.response.json();",
                  "    for (let i = 0; i < recommendations.length - 1; i++) {",
                  "        pm.expect(recommendations[i].score).to.be.at.least(recommendations[i+1].score);",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
