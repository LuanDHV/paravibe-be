              "host": ["{{base_url}}"],
              "path": ["songs"],
              "query": [
                {
                  "key": "q",
                  "value": "bohemian",
                  "description": "Search query by title or artist"
                },
                {
                  "key": "title",
                  "value": "",
                  "description": "Filter by song title",
                  "disabled": true
                },
                {
                  "key": "artistId",
                  "value": "",
                  "description": "Filter by artist ID",
                  "disabled": true
                },
                {
                  "key": "genre",
                  "value": "",
                  "description": "Filter by genre",
                  "disabled": true
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Search songs by title, artist, or genre"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is array', function() {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Songs have required fields', function() {",
                  "    const songs = pm.response.json();",
                  "    if (songs.length > 0) {",
                  "        pm.expect(songs[0]).to.have.property('songId');",
                  "        pm.expect(songs[0]).to.have.property('title');",
                  "        pm.expect(songs[0]).to.have.property('artistId');",
                  "    }",
                  "});"
